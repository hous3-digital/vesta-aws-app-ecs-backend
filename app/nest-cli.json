{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "assets": [
      "**/*.hbs"
    ],
    "watchOptions": {
      "ignored": [
        "**/node_modules/**",
        "**/dist/**",
        "**/*.spec.ts",
        "**/test/**",
        "constructor-args-*.js"
      ]
    }
  }
}
