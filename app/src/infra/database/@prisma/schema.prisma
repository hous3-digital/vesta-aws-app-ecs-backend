generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

generator dbml {
  provider = "prisma-dbml-generator"
  output   = "./dbml"
}

enum CredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model Credential {
  id            String           @unique @map("credential_id")
  nullifier     String?          @unique
  issuer        String?
  kycProvider   String?          @map("kyc_provider")
  kycApproved   Boolean?         @map("kyc_approved")
  issuedAt      DateTime?        @map("issued_at")
  vcHash        String           @unique @map("vc_hash")
  cpfDedupKey   String?          @unique @map("cpf_dedup_key")
  issuerDid     String           @map("issuer_did")
  issuerId      String           @map("issuer_id")
  subjectDid    String           @map("subject_did")
  kycLevel      String           @map("kyc_level")
  status        CredentialStatus @default(ACTIVE)
  sorobanTxHash String?          @map("soroban_tx_hash")
  createdAt     DateTime         @map("created_at")
  updatedAt     DateTime         @map("updated_at")
  expiresAt     DateTime?        @map("expires_at")

  @@index([status])
  @@index([kycProvider])
  @@map("credentials")
}

model Attestation {
  id            String   @unique @map("attestation_id")
  vcHash        String   @map("vc_hash")
  proofHash     String   @map("proof_hash")
  verifierId    String   @map("verifier_id")
  kycLevel      String   @map("kyc_level")
  sorobanTxHash String?  @map("soroban_tx_hash")
  sorobanLedger Int?     @map("soroban_ledger")
  onChainResult Boolean  @map("on_chain_result")
  createdAt     DateTime @map("created_at")

  @@index([vcHash])
  @@map("attestation")
}

model Issuer {
  id        String   @unique @map("issuer_id")
  issuerId  String   @unique @map("issuer_external_id")
  name      String
  status    String   @default("active")
  publicKey String?  @map("public_key")
  createdAt DateTime @map("created_at")

  @@map("issuer")
}

model Ingress {
  id        String   @unique @map("ingress_id")
  request   Json
  response  Json
  createdAt DateTime @map("created_at") @db.Timestamptz(6)

  @@map("ingress")
}

model Egress {
  id        String   @unique @map("egress_id")
  request   Json
  response  Json
  createdAt DateTime @map("created_at") @db.Timestamptz(6)

  @@map("egress")
}
