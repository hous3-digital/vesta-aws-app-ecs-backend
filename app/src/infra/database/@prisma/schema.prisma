generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

generator dbml {
  provider = "prisma-dbml-generator"
  output   = "./dbml"
}

enum CredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model Credential {
  id          String           @id @default(uuid())
  nullifier   String           @unique
  issuer      String
  kycProvider String           @map("kyc_provider")
  kycApproved Boolean          @map("kyc_approved")
  issuedAt    DateTime         @map("issued_at")
  expiresAt   DateTime?        @map("expires_at")
  status      CredentialStatus @default(ACTIVE)
  vcHash      String           @map("vc_hash")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@index([kycProvider])
  @@map("credentials")
}

model Ingress {
  id        String   @id @map("ingress_id")
  request   Json
  response  Json
  createdAt DateTime @map("created_at") @db.Timestamptz(6)

  @@map("ingress")
}

model Egress {
  id        String   @id @map("egress_id")
  request   Json
  response  Json
  createdAt DateTime @map("created_at") @db.Timestamptz(6)

  @@map("egress")
}
