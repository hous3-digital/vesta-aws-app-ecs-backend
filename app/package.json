    "cpy-cli": "^7.0.0",
    "dotenv-cli": "^11.0.0",
    "nest-winston": "^1.10.2",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "react": "^19.2.4",
