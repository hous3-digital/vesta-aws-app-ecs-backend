    "jest": "^30.3.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "prisma-dbml-generator": "^0.12.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
