{
  "name": "backend-template",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "prebuild:clear": "npx rimraf dist",
    "prebuild": "run-s prebuild:clear",
    "prettier:format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "prettier:check": "prettier --check .",
    "lint": "eslint src __tests__ --fix",
    "start": "nest start",
    "start:dev": "npm run build && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "prisma:deploy": "npx prisma migrate deploy --config src/infra/database/@prisma/prisma.config.ts",
    "prisma:gen": "npx prisma generate --config src/infra/database/@prisma/prisma.config.ts",
    "prisma:reset": "npx prisma migrate reset --config src/infra/database/@prisma/prisma.config.ts && npx prisma db seed --config src/infra/database/@prisma/prisma.config.ts",
    "prisma:migrate": "npx prisma migrate dev --config src/infra/database/@prisma/prisma.config.ts",
    "prisma:migrate:test": "dotenv -e .env.test -- npx prisma migrate --config src/infra/database/@prisma/prisma.config.ts",
    "prisma:reset:test": "dotenv -e .env.test -- npx prisma migrate reset -f --config src/infra/database/@prisma/prisma.config.ts && dotenv -e .env.test -- npx prisma db seed --config src/infra/database/@prisma/prisma.config.ts",
    "prisma:cleanup:test": "dotenv -e .env.test -- ts-node -r tsconfig-paths/register ./__tests__/helpers/cleanup.helper.ts",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:up:test": "set -a; source .env.test; set +a; docker-compose -f docker-compose-test.yaml up -d",
    "docker:down:test": "set -a; source .env.test; set +a; docker-compose -f docker-compose-test.yaml down",
    "email:preview": "email dev --dir ./src/private/messenger/templates",
    "audit:ci": "audit-ci --config .audit-ci.json",
    "test:unit": "jest --config config/jest-unit.config.ts",
    "test:integration": "jest --config config/jest-integration.config.ts",
    "test:e2e": "dotenv -e .env.test -- npm run docker:up:test && npx dockerize -wait tcp://localhost:${DATABASE_PORT} -timeout 60s && echo y && npm run prisma:migrate:test && npm run prisma:reset:test && jest --config config/jest-e2e.config.ts && npm run prisma:cleanup:test && npm run docker:down:test",
    "test:cov": "jest --config config/jest-unit.config.ts --coverage"
  },
